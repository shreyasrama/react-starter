{
  "name": "react-starter",
  "version": "1.0.0",
  "description": "A React + Vite template with TailwindCSS, Oxlint, and Prettier pre-configured.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
